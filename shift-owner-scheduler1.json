    {
      "parameters": {
        "jsCode": "// Get current time in IST\nconst now = new Date(\n  new Date().toLocaleString(\"en-US\", { timeZone: \"Asia/Kolkata\" })\n);\n\n// 👉 Move to TOMORROW\nnow.setDate(now.getDate() + 1);\n\n// 🛑 Skip Saturday (6) and Sunday (0)\nconst day = now.getDay();\nif (day === 0 || day === 6) {\n  return [\n    {\n      json: {\n        text: \"⏸️ No shifts tomorrow (Weekend)\"\n      }\n    }\n  ];\n}\n\n// Extract tomorrow's date & month\nconst todayDate = now.getDate();\nconst todayMonth = now\n  .toLocaleString(\"en-US\", { month: \"long\" })\n  .toLowerCase();\n\nconst matched = items.find(item => {\n  const data = item.json;\n\n  const itemDate = Number(\n    String(data[\"Date\"] || data[\" Date\"] || \"\").trim()\n  );\n\n  const itemMonth = String(\n    data[\"Month\"] || data[\" Month\"] || \"\"\n  )\n    .trim()\n    .toLowerCase();\n\n  return (\n    itemDate === todayDate &&\n    itemMonth.includes(todayMonth)\n  );\n});\n\nif (!matched) {\n  return [\n    {\n      json: {\n        error: `❌ No shift found for ${todayDate} ${todayMonth}`\n      }\n    }\n  ];\n}\n\nconst data = matched.json;\n\nconst shiftOwner =\n  data[\"9:00AM - 6:00PM\"] ||\n  data[\"9:00 AM - 6:00 PM\"] ||\n  \"Not assigned\";\n\nconst onCall =\n  data[\"on call support\"] ||\n  data[\" on call support\"] ||\n  \"Not assigned\";\n\nreturn [\n  {\n    json: {\n      text: `📅 *Shift Details (Tomorrow)*\\n\\n🗓 Date: ${todayDate} ${todayMonth}\\n🕘 *9:00AM - 6:00PM*: ${shiftOwner}\\n📞 *On Call Support*: ${onCall}`\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [464, 688],
      "id": "76588a95-713e-4847-999e-910efc288849",
      "name": "Code in JavaScript",
      "alwaysOutputData": true,
      "onError": "continueRegularOutput"
